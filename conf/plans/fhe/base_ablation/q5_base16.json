      "predicates": [
        {"type": "equal", "column": "r_name", "threshold": "", "radixBase": 16, "numDigits": 1},
        {"type": "greater_equal", "column": "o_orderdate", "threshold": "", "radixBase": 16, "numDigits": 3},
        {"type": "less_than", "column": "o_orderdate", "threshold": "", "radixBase": 16, "numDigits": 3}
      ],
      "inputs": ["0"]
    },
    {
      "id": "2",
      "relOp": "FheAggregate",
      "groupBy": [0],
      "aggregates": [{"type": "SUM", "ordinal": 2, "alias": "revenue"}],
